# Application
NAME_APP=GoLightly04API
NODE_ENV=development
PORT=3000
URL_BASE_WEBSITE=http://localhost:3000

# JWT Authentication
JWT_SECRET=your-secret-key-here

# Google Authentication
GOOGLE_CLIENT_ID=your-google-client-id-here

# Logging
PATH_TO_LOGS=/path/to/logs
LOG_MAX_SIZE=5
LOG_MAX_FILES=5

# Worker Node Integration
URL_WORKER_NODE=http://localhost:3002

# Project Resources
PATH_PROJECT_RESOURCES=/path/to/project_resources/golightly04

# Startup Admin User
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=test-password

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
EMAIL_FROM=GoLightly <your-email@gmail.com>

# Postgres configuration
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=golightly04_dev
PG_USER=golightly04_boot
PG_SCHEMA=public
PG_APP_ROLE=golightly04_app
# PG_POOL_MAX=3
